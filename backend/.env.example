# Copy this to backend/.env and fill in your keys. Never commit .env.

# Claude navigation agent (required for agent features)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram speech-to-text (optional, disables voice input if missing)
DEEPGRAM_API_KEY=...

# Sentry error tracking + performance + AI monitoring dashboard
# Create a project at https://sentry.io → Settings → Projects → Add Project (Python)
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Langfuse LLM observability (prompt traces, token costs, agent scoring)
# Sign up at https://cloud.langfuse.com or self-host, then create a project
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # default; change for self-hosted
